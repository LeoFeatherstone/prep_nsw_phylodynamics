<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<!-- "Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81" -->
<!-- Global for clusters -->
<!DOCTYPE note [
    <!ENTITY clusters "Cluster_122,Cluster_161,Cluster_168">
]>

<beast beautitemplate='Standard' beautistatus=''
    namespace="beast.core
            :beast.evolution.alignment
            :beast.evolution.tree.coalescent
            :beast.core.util
            :beast.evolution.nuc
            :beast.evolution.operators
            :beast.evolution.sitemodel
            :beast.evolution.substitutionmodel
            :beast.base.evolution.alignment
            :beast.pkgmgmt
            :beast.base.core
            :beast.base.inference
            :beast.base.evolution.tree.coalescent
            :beast.pkgmgmt
            :beast.base.core
            :beast.base.inference.util
            :beast.evolution.nuc
            :beast.base.evolution.operator
            :beast.base.inference.operator
            :beast.base.evolution.sitemodel
            :beast.base.evolution.substitutionmodel
            :beast.base.evolution.likelihood
            :feast"
    required="BEAST.base v2.7.8BDSKY v1.5.1" version="2.7">

    <map name="Uniform">beast.base.inference.distribution.Uniform</map>
    <map name="Exponential">beast.base.inference.distribution.Exponential</map>
    <map name="LogNormal">beast.base.inference.distribution.LogNormalDistributionModel</map>
    <map name="Normal">beast.base.inference.distribution.Normal</map>
    <map name="Beta">beast.base.inference.distribution.Beta</map>
    <map name="Gamma">beast.base.inference.distribution.Gamma</map>
    <map name="LaplaceDistribution">beast.base.inference.distribution.LaplaceDistribution</map>
    <map name="prior">beast.base.inference.distribution.Prior</map>
    <map name="InverseGamma">beast.base.inference.distribution.InverseGamma</map>
    <map name="OneOnX">beast.base.inference.distribution.OneOnX</map>

    <!-- Data -->
    <plate var="c" range="&clusters;">
        <alignment spec="feast.fileio.AlignmentFromFasta" id="$(c)" fileName="sequences/$(c).fasta" />
    </plate>


    <run id="mcmc" spec="MCMC" chainLength="50000000">
        <state id="state" spec="State" storeEvery="10000">

            <!-- Hard code becomeUninfectiousRates. Use plate later? -->
            <parameter id="becomeUninfectiousRate_Cluster_122" lower="0.0" value="0.29"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_161" lower="0.0" value="0.44"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_168" lower="0.0" value="0.47"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_246" lower="0.0" value="0.47"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_259" lower="0.0" value="0.40"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_266" lower="0.0" value="0.39"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_28" lower="0.0" value="0.46"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_323" lower="0.0" value="0.69"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_361" lower="0.0" value="0.57"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_375" lower="0.0" value="0.48"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_37" lower="0.0" value="0.37"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_413" lower="0.0" value="0.68"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_4" lower="0.0" value="0.41"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_533" lower="0.0" value="0.36"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_76" lower="0.0" value="0.43"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_81" lower="0.0" value="0.45"
                name="stateNode" />

            <plate var="c" range="&clusters;">

                <tree id="Tree$(c)" name="stateNode">
                    <trait id="ageTrait$(c)"
                        spec="feast.fileio.TraitSetFromTaxonSet"
                        delimiter="_"
                        everythingAfterLast="true"
                        traitname="date">
                        <taxa id="taxonSet_$(c)" spec="TaxonSet" alignment="@$(c)" />
                    </trait>

                    <trait id="dateTrait$(c)"
                        spec="feast.fileio.TraitSetFromTaxonSet"
                        delimiter="_"
                        everythingAfterLast="true"
                        traitname="absDate">
                        <taxa spec="TaxonSet" alignment="@$(c)" />
                    </trait>

                    <taxonset idref="taxonSet_$(c)" />
                </tree>

                <parameter id="origin_$(c)" lower="0.0" name="stateNode" upper="Infinity">100</parameter>
                <parameter id="samplingProportion_$(c)" spec="parameter.RealParameter"
                    lower="0.0"
                    name="stateNode" upper="1.0" dimension="2">0.0 0.9</parameter>
            </plate>

            <parameter id="reproductiveNumber"
                spec="parameter.RealParameter" lower="0.0" name="stateNode"
                upper="Infinity">2.0</parameter>
            <parameter id="clockRate" spec="parameter.RealParameter" lower="0.0"
                name="stateNode">0.003</parameter>
            <parameter id="kappa" spec="parameter.RealParameter" lower="0.0"
                name="stateNode">2.0</parameter>
            <parameter id="gammaShape" spec="parameter.RealParameter" lower="0.1"
                name="stateNode">1.0</parameter>

        </state>

        <plate var="c" range="&clusters;">
            <init id="RandomTree_$(c)" spec="RandomTree" estimate="false"
                initial="@Tree$(c)" taxa="@$(c)">
                <populationModel id="ConstantPopulation$(c)" spec="ConstantPopulation">
                    <parameter id="randomPopSize$(c)" spec="parameter.RealParameter"
                        name="popSize">0.01</parameter>
                </populationModel>
            </init>
        </plate>

        <distribution id="posterior" spec="CompoundDistribution">
            <distribution id="prior" spec="CompoundDistribution">

                <plate var="c" range="&clusters;">

                    <distribution id="treePrior_$(c)"
                        spec="bdsky.evolution.speciation.BirthDeathSkylineModel"
                        origin="@origin_$(c)" samplingProportion="@samplingProportion_$(c)"
                        reproductiveNumber="@reproductiveNumber" tree="@Tree$(c)"
                        becomeUninfectiousRate="@becomeUninfectiousRate_$(c)">

                        <samplingRateChangeTimes spec="feast.parameter.RealParameterFromFunction"
                            id="pTreeSlice_$(c)" dimension="2">
                            <function spec="feast.expressions.ExpCalculator"
                                value="{0,max(x_$(c)) + (0.5/365)}">
                                <arg id="x_$(c)" spec="feast.function.TraitSetAsFunction"
                                    traitSet="@ageTrait$(c)" />
                            </function>
                        </samplingRateChangeTimes>

                        <birthRateChangeTimes spec="feast.parameter.RealParameterFromFunction"
                            id="ReTreeSlice_$(c)">

                            
                            <function spec="feast.expressions.ExpCalculator"
                                id="birthRateChangeTimesFunc_$(c)" 
                                value="{0, max(max_time_$(c)) - {2022, 2020, 2017}}">
                                <arg id="max_time_$(c)"
                                    spec="feast.function.TraitSetAsFunction"
                                    traitSet="@dateTrait$(c)" />
                            </function>
                            
                        </birthRateChangeTimes>

                    </distribution>

                    <prior id="samplingProportionPrior_$(c)" x="@samplingProportion_$(c)"
                            name="distribution">
                        <Uniform name="distr" upper="1" lower="0" />
                    </prior>

                    <prior name="distribution" x="@origin_$(c)">
                        <!-- This was uniform, move to lognormal for consistency and to place weight
                        closer to acquisition -->
                        <Uniform name="distr" upper="100" lower="0" />
                        <!-- <LogNormal name="distr">
                            <parameter estimate="false" name="M">-2</parameter>
                            <parameter estimate="false" lower="0.0" name="S" upper="5.0">0.8</parameter>
                        </LogNormal> -->
                    </prior>
                </plate>


                <prior id="ClockPrior" name="distribution"
                    x="@clockRate">
                    <Uniform id="Uniform.0" name="distr" upper="Infinity" />
                </prior>

                <prior id="GammaShapePrior" name="distribution"
                    x="@gammaShape">
                    <Exponential id="Exponential.0" name="distr">
                        <parameter id="RealParameter.0" spec="parameter.RealParameter"
                            estimate="false" name="mean">1.0</parameter>
                    </Exponential>
                </prior>
                <prior id="KappaPrior" name="distribution" x="@kappa">
                    <LogNormal id="LogNormalDistributionModel.0" name="distr">
                        <parameter id="RealParameter.48" spec="parameter.RealParameter"
                            estimate="false" name="M">1.0</parameter>
                        <parameter id="RealParameter.49" spec="parameter.RealParameter"
                            estimate="false" name="S">1.25</parameter>
                    </LogNormal>
                </prior>

                <prior id="reproductiveNumberPrior" name="distribution"
                    x="@reproductiveNumber">
                    <LogNormal id="LogNormalDistributionModel.2" name="distr">
                        <parameter id="RealParameter.55" spec="parameter.RealParameter"
                            estimate="false" name="M">0.0</parameter>
                        <parameter id="RealParameter.56" spec="parameter.RealParameter"
                            estimate="false" name="S">1.0</parameter>
                    </LogNormal>
                </prior>
            </distribution>

            <plate var="c" range="&clusters;">
                <distribution id="likelihood_$(c)" spec="CompoundDistribution" useThreads="true">
                    <distribution id="treeLikelihood_$(c)" spec="ThreadedTreeLikelihood"
                        data="@$(c)" tree="@Tree$(c)">
                        <siteModel id="SiteModel_$(c)" spec="SiteModel" gammaCategoryCount="4"
                            shape="@gammaShape">
                            <parameter id="mutationRate_$(c)" spec="parameter.RealParameter"
                                estimate="false" lower="0.0" name="mutationRate">1.0</parameter>
                            <parameter id="proportionInvariant_$(c)"
                                spec="parameter.RealParameter" estimate="false" lower="0.0"
                                name="proportionInvariant" upper="1.0">0.0</parameter>
                            <substModel spec="HKY" kappa="@kappa">
                                <frequencies spec="Frequencies" data="@$(c)" />
                            </substModel>
                        </siteModel>
                        <branchRateModel id="StrictClock_$(c)"
                            spec="beast.base.evolution.branchratemodel.StrictClockModel"
                            clock.rate="@clockRate" />
                    </distribution>
                </distribution>
            </plate>

        </distribution>
        <!-- <operator id="StrictClockRateScaler" spec="AdaptableOperatorSampler"
            weight="1.5">
            <parameter idref="clockRate" />
            <operator id="AVMNOperator"
                spec="kernel.AdaptableVarianceMultivariateNormalOperator" allowNonsense="true"
                beta="0.05" burnin="400" initial="800" weight="0.1">
                <transformations id="AVMNLogTransform"
                    spec="operator.kernel.Transform$LogTransform">
                    <f idref="clockRate" />
                    <f idref="kappa" />
                    <f idref="gammaShape" />
                </transformations>
                <transformations id="AVMNNoTransform"
                    spec="operator.kernel.Transform$NoTransform">
                    <f idref="Tree" />
                </transformations>
            </operator>
            <operator id="StrictClockRateScalerX" spec="kernel.BactrianScaleOperator"
                parameter="@clockRate" upper="10.0" weight="3.0" />
        </operator>
        <operator id="strictClockUpDownOperator" spec="AdaptableOperatorSampler"
            weight="1.5">
            <parameter idref="clockRate" />
            <tree idref="Tree" />
            <operator idref="AVMNOperator" />
            <operator id="strictClockUpDownOperatorX"
                spec="operator.kernel.BactrianUpDownOperator" scaleFactor="0.75" weight="3.0">
                <up idref="clockRate" />
                <down idref="Tree" />
            </operator>
        </operator> -->
        <operator id="KappaScaler" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="kappa" />
            <!-- <operator idref="AVMNOperator" /> -->
            <operator id="KappaScalerX" spec="kernel.BactrianScaleOperator"
                parameter="@kappa" scaleFactor="0.1" upper="10.0" weight="0.1" />
        </operator>
        <!-- <operator id="FrequenciesExchanger" spec="AdaptableOperatorSampler"
            weight="0.05">
            <parameter idref="freqParameter" />
            <operator idref="AVMNOperator" />
            <operator id="FrequenciesExchangerX"
                spec="operator.kernel.BactrianDeltaExchangeOperator" delta="0.01" weight="0.1">
                <parameter idref="freqParameter" />
            </operator>
        </operator> -->
        <operator id="gammaShapeScaler" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="gammaShape" />
            <!-- <operator idref="AVMNOperator" /> -->
            <operator id="gammaShapeScalerX" spec="kernel.BactrianScaleOperator"
                parameter="@gammaShape" scaleFactor="0.5" upper="10.0" weight="0.1" />
        </operator>

        <operator id="reproductiveNumberScaler" spec="ScaleOperator"
            parameter="@reproductiveNumber" weight="10.0" />


        <plate var="c" range="&clusters;">
            <operator id="samplingProportionScaler_$(c)" spec="ScaleOperator"
                parameter="@samplingProportion_$(c)" weight="10.0" />
            <operator id="origScaler_$(c)" spec="ScaleOperator"
                parameter="@origin_$(c)" weight="1.0" />
            <operator id="BICEPSEpochTop_$(c)" spec="EpochFlexOperator"
                scaleFactor="0.1" tree="@Tree$(c)" weight="2.0" />
            <operator id="BICEPSEpochAll_$(c)" spec="EpochFlexOperator"
                fromOldestTipOnly="false" scaleFactor="0.1" tree="@Tree$(c)" weight="2.0" />
            <operator id="BICEPSTreeFlex_$(c)" spec="TreeStretchOperator"
                scaleFactor="0.01" tree="@Tree$(c)" weight="2.0" />
            <operator id="TreeRootScaler_$(c)" spec="kernel.BactrianScaleOperator"
                rootOnly="true" scaleFactor="0.1" tree="@Tree$(c)" upper="10.0" weight="3.0" />
            <operator id="UniformOperator_$(c)" spec="kernel.BactrianNodeOperator"
                tree="@Tree$(c)" weight="30.0" />
            <operator id="SubtreeSlide_$(c)" spec="kernel.BactrianSubtreeSlide"
                tree="@Tree$(c)" weight="15.0" />
            <operator id="Narrow_$(c)" spec="Exchange" tree="@Tree$(c)"
                weight="15.0" />
            <operator id="Wide_$(c)" spec="Exchange" isNarrow="false"
                tree="@Tree$(c)" weight="3.0" />
            <operator id="WilsonBalding_$(c)" spec="WilsonBalding"
                tree="@Tree$(c)" weight="3.0" />
        </plate>

        <logger id="tracelog" spec="Logger" fileName="$(filebase).log" logEvery="10000"
            model="@posterior" sanitiseHeaders="true" sort="smart">
            <plate var="c" range="&clusters;">
                <log idref="pTreeSlice_$(c)" />
                <log idref="likelihood_$(c)" />
                <log idref="treeLikelihood_$(c)" />
                <log id="TreeHeight_$(c)" spec="beast.base.evolution.tree.TreeStatLogger" tree="@Tree$(c)" />
                <log idref="samplingProportion_$(c)" />
                <log idref="treePrior_$(c)" />
                <log idref="origin_$(c)" />
            </plate>

            <log idref="posterior" />
            <log idref="prior" />
            <log idref="clockRate" />
            <log idref="kappa" />
            <!-- <log idref="freqParameter" /> -->
            <log idref="gammaShape" />
            <log idref="reproductiveNumber" />

        </logger>
        <logger id="screenlog" spec="Logger" logEvery="10000">
            <log idref="reproductiveNumber" />
            <plate var="c" range="&clusters;">
                <log idref="birthRateChangeTimesFunc_$(c)" />
                <log idref="likelihood_$(c)" />
            </plate>
            <log idref="posterior" />
            <log idref="prior" />
        </logger>
        <!-- <logger id="treelog" spec="Logger" fileName="re_averaged.trees"
            logEvery="10000" mode="tree">
            <log id="TreeWithMetaDataLogger"
                spec="beast.base.evolution.TreeWithMetaDataLogger" tree="@Tree$(c)" />
        </logger> -->
        <operatorschedule id="OperatorSchedule" spec="OperatorSchedule" />
    </run>

</beast>