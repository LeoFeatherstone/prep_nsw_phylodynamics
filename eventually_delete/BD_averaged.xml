<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<beast beautitemplate='Standard' beautistatus=''
    namespace="beast.core:
            beast.evolution.alignment:
            beast.evolution.tree.coalescent:
            beast.core.util:
            beast.evolution.nuc:
            beast.evolution.operators:
            beast.evolution.sitemodel:
            beast.evolution.substitutionmodel:
            beast.base.evolution.alignment:
            beast.pkgmgmt:
            beast.base.core:
            beast.base.inference:
            beast.base.evolution.tree.coalescent:
            beast.pkgmgmt:
            beast.base.core:
            beast.base.inference.util:
            beast.evolution.nuc:
            beast.base.evolution.operator:
            beast.base.inference.operator:
            beast.base.evolution.sitemodel:
            beast.base.evolution.substitutionmodel:
            beast.base.evolution.likelihood:
            feast:"
    required="BEAST.base v2.7.6:BDSKY v1.5.0" version="2.7">

    <plate var="outbreak"
        range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">
        <alignment spec="feast.fileio.AlignmentFromFasta" id="$(outbreak)"
            fileName="sequences/$(outbreak).fasta" />
    </plate>


    <map name="Uniform">beast.base.inference.distribution.Uniform</map>
    <map name="Exponential">beast.base.inference.distribution.Exponential</map>
    <map name="LogNormal">beast.base.inference.distribution.LogNormalDistributionModel</map>
    <map name="Normal">beast.base.inference.distribution.Normal</map>
    <map name="Beta">beast.base.inference.distribution.Beta</map>
    <map name="Gamma">beast.base.inference.distribution.Gamma</map>
    <map name="LaplaceDistribution">beast.base.inference.distribution.LaplaceDistribution</map>
    <map name="prior">beast.base.inference.distribution.Prior</map>
    <map name="InverseGamma">beast.base.inference.distribution.InverseGamma</map>
    <map name="OneOnX">beast.base.inference.distribution.OneOnX</map>

    <run id="mcmc" spec="MCMC" chainLength="50000000">

        <state id="state" spec="State" storeEvery="10000">

            <parameter id="becomeUninfectiousRate_Cluster_122" lower="0.0" value="0.29"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_161" lower="0.0" value="0.44"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_168" lower="0.0" value="0.47"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_246" lower="0.0" value="0.47"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_259" lower="0.0" value="0.40"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_266" lower="0.0" value="0.39"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_28" lower="0.0" value="0.46"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_323" lower="0.0" value="0.69"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_361" lower="0.0" value="0.57"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_375" lower="0.0" value="0.48"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_37" lower="0.0" value="0.37"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_413" lower="0.0" value="0.68"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_4" lower="0.0" value="0.41"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_533" lower="0.0" value="0.36"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_76" lower="0.0" value="0.43"
                name="stateNode" />
            <parameter id="becomeUninfectiousRate_Cluster_81" lower="0.0" value="0.45"
                name="stateNode" />

            <plate var="m"
                range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">
                <tree id="Tree.t:$(m)" name="stateNode">
                    <trait id="traitSet_$(m)"
                        spec="feast.fileio.TraitSetFromTaxonSet"
                        delimiter="_"
                        everythingAfterLast="true"
                        traitname="date-forward">
                        <taxa id="taxonSet_$(m)" spec="TaxonSet" alignment="@$(m)" />
                    </trait>

                    <trait id="absoluteDate_$(m)"
                        spec="feast.fileio.TraitSetFromTaxonSet"
                        delimiter="_"
                        everythingAfterLast="true"
                        traitname="absoluteDate">
                        <taxa spec="TaxonSet" alignment="@$(m)" />
                </trait>

                    <taxonset idref="taxonSet_$(m)" />


                </tree>

            </plate>

            <plate var="m"
                range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">
                <parameter id="origin_$(m)" lower="0.0" name="stateNode" upper="Infinity">100</parameter>
                <parameter id="sampProp_$(m)" spec="parameter.RealParameter" lower="0.0"
                    name="stateNode" upper="1.0" dimension="2">0 0.9</parameter>
            </plate>

            <parameter id="clockRate" spec="parameter.RealParameter" name="stateNode">3e-3</parameter>
            <parameter id="kappa" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>
            <parameter id="gammaShape" spec="parameter.RealParameter" name="stateNode">1.0</parameter>

            <parameter id="reproductiveNumber" spec="parameter.RealParameter" dimension="4"
                lower="0.0" name="stateNode" upper="Infinity">2.0</parameter>
            <!-- Old skylinetools change time declaration. See below for update -->
            <!-- <parameter id="reproductiveNumberChangeTimes" name="stateNode" dimension="3">2017
            2020 2022</parameter> -->
            <!-- The intervals are everything before the end of 2016, which is PREP was deployed
            (trialed). Then the before covid years, the covid period, and after -->
        </state>


        <plate var="m"
            range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">
            <init spec="beast.base.evolution.tree.coalescent.RandomTree" estimate="false"
                initial="@Tree.t:$(m)" taxa="@$(m)">
                <populationModel spec="ConstantPopulation">
                    <parameter name="popSize">1</parameter>
                </populationModel>
            </init>
        </plate>

        <distribution id="posterior" spec="beast.base.inference.CompoundDistribution">
            <distribution id="prior" spec="beast.base.inference.CompoundDistribution">

                <plate var="m"
                    range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">

                    <distribution id="treePrior_$(m)"
                        spec="bdsky.evolution.speciation.BirthDeathSkylineModel"
                        origin="@origin_$(m)" samplingProportion="@sampProp_$(m)"
                        reproductiveNumber="@reproductiveNumber" tree="@Tree.t:$(m)"
                        becomeUninfectiousRate="@becomeUninfectiousRate_$(m)">

                        <samplingRateChangeTimes spec="feast.parameter.RealParameterFromFunction"
                            id="PTreeSlice_$(m)" dimension="2">
                            <function spec="feast.expressions.ExpCalculator"
                                value="{0,max(taxonTimes_$(m)_1)+0.5/365}">
                                <arg id="taxonTimes_$(m)_1" spec="feast.function.TraitSetAsFunction"
                                    traitSet="@traitSet_$(m)" />
                            </function>
                        </samplingRateChangeTimes>

                        <!-- <birthRateChangeTimes
                        spec="beast.base.inference.parameter.RealParameter"
                            idref="changeTimes" dimension="4"/> -->

                        <birthRateChangeTimes spec="feast.parameter.RealParameterFromFunction"
                            id="ReTreeSlice_$(m)" dimension="4">
                            <function
                                spec="feast.expressions.ExpCalculator"
                                value="{0, max(dates_$(m) - {2022, 2020, 2017}) }">

                                    <arg id="dates_$(m)"
                                        spec="feast.function.TraitSetAsFunction"
                                        traitSet="@absoluteDate_$(m)" />

                            </function>
                        </birthRateChangeTimes>

                        <!-- Order here:
                         Here, we are telling the model to use the opposite direction of time to the default in five
                        dimensions: in order, this refers to our three rate parameters (birth, death
                        and sampling) plus rho and the removalProbability 
                         https://taming-the-beast.org/tutorials/Skyline-analyses-for-macroevolution/
                         ... I need to look this up every time
                        -->
                        <reverseTimeArrays spec="beast.base.inference.parameter.BooleanParameter"
                            value="true true true true true" />

                    </distribution>

                    <prior id="sampPropPrior_$(m)" name="distribution">
                        <x spec="feast.function.Slice" arg="@sampProp_$(m)"
                            index="1" count="1" />
                        <Beta name="distr" alpha="1" beta="1" />
                    </prior>
                    <prior name="distribution" x="@origin_$(m)">
                        <Uniform name="distr" upper="100" lower="0" />
                    </prior>
                </plate>


                <prior id="GammaShapePrior" name="distribution" x="@gammaShape">
                    <Exponential id="Exponential.0" name="distr">
                        <parameter id="RealParameter.0" spec="parameter.RealParameter"
                            estimate="false" name="mean">1.0</parameter>
                    </Exponential>
                </prior>
                <prior id="KappaPrior.s:cluster1_renamed" name="distribution" x="@kappa">
                    <LogNormal id="LogNormalDistributionModel.0" name="distr">
                        <parameter id="RealParameter.3" spec="parameter.RealParameter"
                            estimate="false" name="M">1.0</parameter>
                        <parameter id="RealParameter.4" spec="parameter.RealParameter"
                            estimate="false" name="S">1.25</parameter>
                    </LogNormal>
                </prior>
                <prior id="reproductiveNumberPrior" name="distribution" x="@reproductiveNumber">
                    <LogNormal id="LogNormalDistributionModel.2" name="distr">
                        <parameter id="RealParameter.9" spec="parameter.RealParameter"
                            estimate="false" name="M">1.0</parameter>
                        <parameter id="RealParameter.10" spec="parameter.RealParameter"
                            estimate="false" name="S">1.0</parameter>
                    </LogNormal>
                </prior>

            </distribution>
            <distribution id="likelihood" spec="beast.base.inference.CompoundDistribution"
                useThreads="true">
                <plate var="m"
                    range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">
                    <distribution id="treeLikelihood.$(m)" spec="ThreadedTreeLikelihood"
                        data="@$(m)" tree="@Tree.t:$(m)">
                        <siteModel id="SiteModel.s:$(m)" spec="SiteModel" gammaCategoryCount="4"
                            shape="@gammaShape">
                            <parameter id="mutationRate.s:$(m)" estimate="false"
                                name="mutationRate">
                                1.0</parameter>
                            <parameter id="proportionInvariant.s:$(m)" estimate="false" lower="0.0"
                                name="proportionInvariant" upper="1.0">0.0</parameter>
                            <substModel spec="HKY" kappa="@kappa">
                                <frequencies spec="Frequencies" data="@$(m)" />
                            </substModel>
                        </siteModel>
                        <branchRateModel id="StrictClock.c:$(m)"
                            spec="beast.base.evolution.branchratemodel.StrictClockModel">
                            <parameter name="clock.rate" idref="clockRate" />
                        </branchRateModel>
                    </distribution>
                </plate>
            </distribution>

        </distribution>
        <!--operator
        id="StrictClockRateScaler.c:cluster3_renamed" spec="ScaleOperator" parameter="@clockRate"
        weight="3.0"/-->

        <operator id="KappaScaler" spec="ScaleOperator" parameter="@kappa" scaleFactor="0.5"
            weight="0.1" />
        <operator id="gammaShapeScaler" spec="ScaleOperator" parameter="@gammaShape"
            scaleFactor="0.5" weight="0.1" />
        <operator id="reproductiveNumberScaler" spec="ScaleOperator" parameter="@reproductiveNumber"
            weight="10.0" />
        <plate var="m"
            range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">
            <operator id="samplingProportionScaler$(m)" spec="ScaleOperator"
                parameter="@sampProp_$(m)" scaleFactor="0.75" weight="10.0" />
            <operator id="origScaler_$(m)" spec="ScaleOperator" parameter="@origin_$(m)"
                scaleFactor="0.75" weight="1.0" />
        </plate>
        <!--need
        sampling proportion scalers and origin-->
        <logger id="tracelog" spec="Logger" fileName="BD_averaged.log" logEvery="10000"
            model="@posterior" sanitiseHeaders="true" sort="smart">
            <log idref="posterior" />
            <log idref="likelihood" />
            <log idref="prior" />
            <plate var="m"
                range="Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81">
                <log idref="sampProp_$(m)" />
                <log idref="origin_$(m)" />
                <log idref="becomeUninfectiousRate_$(m)" />
                <log idref="ReTreeSlice_$(m)" />
                <log idref="PTreeSlice_$(m)" />

                <!-- <log idreg="someTrait_$(m)" /> -->

            </plate>
            <log idref="reproductiveNumber" />
        </logger>
        <logger id="screenlog" spec="Logger" logEvery="100000">
            <log idref="posterior" />
            <log idref="likelihood" />
            <log idref="prior" />
            <log idref="reproductiveNumber" />

        </logger>

    </run>
</beast>