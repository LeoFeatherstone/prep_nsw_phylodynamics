<!--
"Cluster_122,Cluster_161,Cluster_168,Cluster_246,Cluster_259,Cluster_266,Cluster_28,Cluster_323,Cluster_361,Cluster_375,Cluster_37,Cluster_413,Cluster_4,Cluster_533,Cluster_76,Cluster_81" -->

<!-- Global for clusters -->
<!DOCTYPE note [
    <!ENTITY clusters "Cluster_122,Cluster_161,Cluster_168">
]>

<beast beautitemplate='Standard' beautistatus=''
    namespace="beast.core
    :beast.evolution.alignment
    :beast.evolution.tree.coalescent
    :beast.core.util
    :beast.evolution.nuc
    :beast.evolution.operators
    :beast.evolution.sitemodel
    :beast.evolution.substitutionmodel
    :beast.base.evolution.alignment
    :beast.pkgmgmt
    :beast.base.core
    :beast.base.inference
    :beast.base.evolution.tree.coalescent
    :beast.pkgmgmt
    :beast.base.core
    :beast.base.inference.util
    :beast.evolution.nuc
    :beast.base.evolution.operator
    :beast.base.inference.operator
    :beast.base.evolution.sitemodel
    :beast.base.evolution.substitutionmodel
    :beast.base.evolution.likelihood"
    required="BEAST.base v2.7.8:BDMM-Prime v2.4.0:SA v2.1.1" version="2.7">

    <!-- Data -->
    <plate var="c" range="&clusters;">
        <alignment spec="feast.fileio.AlignmentFromFasta" id="$(c)" fileName="sequences/$(c).fasta" />
    </plate>

    <map name="Uniform">beast.base.inference.distribution.Uniform</map>
    <map name="Exponential">beast.base.inference.distribution.Exponential</map>
    <map name="LogNormal">beast.base.inference.distribution.LogNormalDistributionModel</map>
    <map name="Normal">beast.base.inference.distribution.Normal</map>
    <map name="Beta">beast.base.inference.distribution.Beta</map>
    <map name="Gamma">beast.base.inference.distribution.Gamma</map>
    <map name="LaplaceDistribution">beast.base.inference.distribution.LaplaceDistribution</map>
    <map name="prior">beast.base.inference.distribution.Prior</map>
    <map name="InverseGamma">beast.base.inference.distribution.InverseGamma</map>
    <map name="OneOnX">beast.base.inference.distribution.OneOnX</map>

    <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_122"
                index="0" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_161"
                index="1" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_168"
                index="2" count="1" arg="@ReEpi" />
            <!-- <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_246"
                index="3" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_259"
                index="4" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_266"
                index="5" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_28"
                index="6" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_323"
                index="7" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_361"
                index="8" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_375"
                index="9" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_37"
                index="10" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_413"
                index="11" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_4"
                index="12" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_533"
                index="13" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_76"
                index="14" count="1" arg="@ReEpi" />
            <reproductiveNumber spec="feast.function.Slice" id="ReEpiCluster_81"
                index="15" count="1" arg="@ReEpi" /> -->

    <run id="mcmc" spec="MCMC" chainLength="750000000" storeEvery="10000">
        <state id="state" spec="State" storeEvery="5000">

            <!-- Hard code becomeUninfectiousRates. Use plate later? -->
            <parameter id="becomeUninfectiousRateEpiCluster_122" lower="0.0" value="0.29"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_161" lower="0.0" value="0.44"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_168" lower="0.0" value="0.47"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_246" lower="0.0" value="0.47"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_259" lower="0.0" value="0.40"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_266" lower="0.0" value="0.39"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_28" lower="0.0" value="0.46"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_323" lower="0.0" value="0.69"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_361" lower="0.0" value="0.57"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_375" lower="0.0" value="0.48"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_37" lower="0.0" value="0.37"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_413" lower="0.0" value="0.68"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_4" lower="0.0" value="0.41"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_533" lower="0.0" value="0.36"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_76" lower="0.0" value="0.43"
                name="stateNode" />
            <parameter id="becomeUninfectiousRateEpiCluster_81" lower="0.0" value="0.45"
                name="stateNode" />

            <plate var="c" range="&clusters;">
                <tree id="Tree.$(c)" spec="beast.base.evolution.tree.Tree" name="stateNode">
                    <trait id="dateTrait$(c)"
                        spec="feast.fileio.TraitSetFromTaxonSet"
                        delimiter="_"
                        everythingAfterLast="true"
                        traitname="date-backward">
                        <taxa id="TaxonSet.$(c)" spec="TaxonSet" alignment="@$(c)" />
                    </trait>
                    <trait id="absDateTrait$(c)"
                        spec="feast.fileio.TraitSetFromTaxonSet"
                        delimiter="_"
                        everythingAfterLast="true"
                        traitname="absoluteDate">
                        <taxa spec="TaxonSet" alignment="@$(c)" />
                    </trait>
                    <taxonset idref="TaxonSet.$(c)" />
                </tree>

                <parameter id="samplingProportionEpi$(c)" spec="parameter.RealParameter"
                    dimension="2"
                    lower="0.0" name="stateNode" upper="1.0">0.0 0.9</parameter>
                <parameter id="origin$(c)" spec="parameter.RealParameter" name="stateNode">100.0</parameter>

            </plate>

            <parameter id="clockRate" spec="parameter.RealParameter" lower="0.0" name="stateNode">
                0.003</parameter>
            <parameter id="gammaShape" spec="parameter.RealParameter" lower="0.1" name="stateNode">
                1.0</parameter>
            <parameter id="kappa" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="ReEpi" spec="parameter.RealParameter" dimension="3" minordimension="4" lower="0.0"
                name="stateNode">1.0 1.0 1.0 1.0</parameter>

            <stateNode id="dirichletScale" spec="parameter.RealParameter" dimension="4" lower="0"
                value="1.0" />

        </state>

        <!-- == Initial Trees == -->
        <plate var="c" range="&clusters;">
            <init spec="RandomTree" estimate="false" initial="@Tree.$(c)" taxa="@$(c)">
                <populationModel spec="ConstantPopulation">
                    <parameter spec="parameter.RealParameter" name="popSize">1.0</parameter>
                </populationModel>
            </init>
        </plate>

        <!-- == Target Distribution == -->
        <distribution id="posterior" spec="CompoundDistribution">
            <distribution id="prior" spec="CompoundDistribution">

                <plate var="c" range="&clusters;">

                    <distribution id="BDMMPrime$(c)"
                        spec="bdmmprime.distribution.BirthDeathMigrationDistribution"
                        conditionOnSurvival="false"
                        tree="@Tree.$(c)">

                        <finalSampleOffset id="fso$(c)"
                            spec="feast.parameter.RealParameterFromFunction">
                            <!-- Global max sample date is 2023.9. FSO = 2023.9 - cluster_max -->
                            <function spec="feast.expressions.ExpCalculator"
                                value="2023.9 - max(dates$(c))">
                                <arg id="dates$(c)" spec="feast.function.TraitSetAsFunction"
                                    traitSet="@absDateTrait$(c)" />
                            </function>
                        </finalSampleOffset>

                        <parameterization id="EpiBDMMPrimeParameterization$(c)"
                            spec="bdmmprime.parameterization.EpiParameterization"
                            processLength="@origin$(c)">
                            <Re id="ReSPEpi$(c)"
                                spec="bdmmprime.parameterization.SkylineVectorParameter"
                                processLength="@origin$(c)" skylineValues="@ReEpi$(c)"
                                timesAreAges="true"
                                timesAreRelative="true">
                                <!-- changeTimes 2023.9 - c(2022, 2020, 2017) -->
                                <parameter id="ReChangeTimesEpi$(c)" spec="parameter.RealParameter"
                                    dimension="3" estimate="false" lower="0.0" name="changeTimes">
                                    1.9 3.9 6.9
                                </parameter>
                                <!-- == Can we remove typeset == -->
                                <!-- == Removed typeset="@typeSetBDMMPrime" in becomeUninfectious,
                                Sampling, and removal probs below -->
                                <!-- <typeSet id="typeSetBDMMPrime"
                                spec="bdmmprime.parameterization.TypeSet">
                                <typeTraitSet id="typeTraitSet"
                                    spec="bdmmprime.util.InitializedTraitSet" traitname="type"
                                value="Seq0100_Cluster-37_2015.2=NOT_SET,Seq0102_Cluster-37_2017.65=NOT_SET,Seq0106_Cluster-37_2015.77=NOT_SET,Seq0101_Cluster-37_2015.18=NOT_SET,Seq0103_Cluster-37_2019.48=NOT_SET,Seq0104_Cluster-37_2019.36=NOT_SET,Seq0105_Cluster-37_2015.89=NOT_SET,Seq0107_Cluster-37_2015.83=NOT_SET,Seq0116_Cluster-37_2012.35=NOT_SET,Seq0117_Cluster-37_2013.57=NOT_SET,Seq0118_Cluster-37_2013.57=NOT_SET,Seq0111_Cluster-37_2013.95=NOT_SET,Seq0110_Cluster-37_2011.37=NOT_SET,Seq0109_Cluster-37_2012.68=NOT_SET,Seq0112_Cluster-37_2014.03=NOT_SET,Seq0113_Cluster-37_2014.13=NOT_SET,Seq0108_Cluster-37_2013.63=NOT_SET,Seq0114_Cluster-37_2018.65=NOT_SET,Seq0115_Cluster-37_2018.54=NOT_SET">
                                    <taxa id="TaxonSet.1" spec="TaxonSet" alignment="@$(c)" />
                                </typeTraitSet>
                            </typeSet> -->
                            </Re>

                            <becomeUninfectiousRate id="becomeUninfectiousRateSPEpi$(c)"
                                skylineValues="@becomeUninfectiousRateEpi$(c)"
                                spec="bdmmprime.parameterization.SkylineVectorParameter"
                                processLength="@origin$(c)" timesAreAges="true" />

                            <samplingProportion id="samplingProportionSPEpi$(c)"
                                spec="bdmmprime.parameterization.SkylineVectorParameter"
                                processLength="@origin$(c)"
                                skylineValues="@samplingProportionEpi$(c)"
                                timesAreAges="true">
                                <parameter id="samplingRateChangeTimesEpi$(c)" name="changeTimes"
                                    spec="feast.parameter.RealParameterFromFunction">
                                    <function spec="feast.expressions.ExpCalculator"
                                        value="min(ages$(c))-0.5/365.25">
                                        <arg id="ages$(c)" spec="feast.function.TraitSetAsFunction"
                                            traitSet="@dateTrait$(c)" />
                                    </function>
                                </parameter>
                            </samplingProportion>

                            <removalProb id="removalProbSPEpi$(c)"
                                spec="bdmmprime.parameterization.SkylineVectorParameter"
                                processLength="@origin$(c)" timesAreAges="true">
                                <parameter id="removalProbEpi$(c)" spec="parameter.RealParameter"
                                    estimate="false" lower="0.0" name="skylineValues" upper="1.0">
                                    1.0</parameter>
                            </removalProb>
                        </parameterization>
                    </distribution>

                    <prior id="origin$(c)Prior" name="distribution" x="@origin$(c)">
                        <Uniform name="distr" upper="Infinity" />
                    </prior>

                    <distribution id="samplingProportionEpi$(c)Prior"
                        spec="bdmmprime.util.priors.ZeroExcludingPrior"
                        x="@samplingProportionEpi$(c)">
                        <Uniform name="distr" lower="0" upper="1" />
                    </distribution>

                </plate>

                <distribution id="ReEpiPrior" spec="feast.modelselect.DirichletProcessPrior"
                    parameter="@ReEpi" scaleParameter="@dirichletScale">
                    <LogNormal id="baseReDistr" name="baseDistr" M="0.8" S="0.5" />
                </distribution>

                <!-- Hyperprior on scale parameter with shape and inverse scale parameters
                 0.512 and 0.029 to induce a roughly uniform prior on the number of
                 unique Re values, following Dorazio 2009. -->
                <prior id="dirichletScalePrior" name="distribution" x="@dirichletScale">
                    <Gamma name="distr" alpha="0.512" beta="34.48275862068965" />
                </prior>

                <!-- Re averaged prior -->
                <!-- <distribution id="ReEpiPrior" spec="bdmmprime.util.priors.ZeroExcludingPrior"
                    x="@ReEpi">
                    <LogNormal id="LogNormalDistributionModel.1" name="distr">
                        <parameter id="RealParameter.9" spec="parameter.RealParameter"
                            estimate="false" name="M">1.0</parameter>
                        <parameter id="RealParameter.10" spec="parameter.RealParameter"
                            estimate="false" lower="0.0" name="S" upper="5.0">1.25</parameter>
                    </LogNormal>
                </distribution> -->

                <prior id="ClockPrior" name="distribution" x="@clockRate">
                    <Uniform id="Uniform.0" name="distr" upper="Infinity" />
                </prior>
                <prior id="GammaShapePrior" name="distribution" x="@gammaShape">
                    <Exponential id="Exponential.0" name="distr">
                        <parameter id="RealParameter.0" spec="parameter.RealParameter"
                            estimate="false" name="mean">1.0</parameter>
                    </Exponential>
                </prior>
                <prior id="KappaPrior" name="distribution" x="@kappa">
                    <LogNormal id="LogNormalDistributionModel.0" name="distr">
                        <parameter id="RealParameter.3" spec="parameter.RealParameter"
                            estimate="false" name="M">1.0</parameter>
                        <parameter id="RealParameter.4" spec="parameter.RealParameter"
                            estimate="false" name="S">1.25</parameter>
                    </LogNormal>
                </prior>

            </distribution>

            <plate var="c" range="&clusters;">
                <distribution id="likelihood$(c)" spec="CompoundDistribution" useThreads="true">
                    <distribution id="treeLikelihood$(c)" spec="ThreadedTreeLikelihood"
                        data="@$(c)" tree="@Tree.$(c)">
                        <siteModel id="SiteModel$(c)" spec="SiteModel" gammaCategoryCount="4"
                            shape="@gammaShape">
                            <parameter id="mutationRate$(c)" spec="parameter.RealParameter"
                                estimate="false"
                                lower="0.0" name="mutationRate">1.0</parameter>
                            <parameter id="proportionInvariant$(c)" spec="parameter.RealParameter"
                                estimate="false" lower="0.0" name="proportionInvariant" upper="1.0">
                                0.0</parameter>
                            <substModel id="hky$(c)" spec="HKY" kappa="@kappa">
                                <frequencies id="empiricalFreqs$(c)" spec="Frequencies" data="@$(c)" />
                            </substModel>
                        </siteModel>
                        <branchRateModel id="StrictClock$(c)"
                            spec="beast.base.evolution.branchratemodel.StrictClockModel"
                            clock.rate="@clockRate" />
                    </distribution>
                </distribution>
            </plate>
        </distribution>

        <!-- == Operators == -->

        <!-- Comment our clock rate operators to fix value -->
        <!-- <operator id="StrictClockRateScaler" spec="AdaptableOperatorSampler" weight="1.5">
            <parameter idref="clockRate" />
            <operator id="AVMNOperator.$(c)"
                spec="kernel.AdaptableVarianceMultivariateNormalOperator" allowNonsense="true"
                beta="0.05" burnin="400" initial="800" weight="0.1">
                <transformations id="AVMNSumTransform.$(c)"
                    spec="operator.kernel.Transform$LogConstrainedSumTransform" />
                <transformations id="AVMNLogTransform.$(c)"
                    spec="operator.kernel.Transform$LogTransform">
                    <f idref="clockRate" />
                    <f idref="gammaShape" />
                    <f idref="kappa" />
                </transformations>
                <transformations id="AVMNNoTransform.$(c)"
                    spec="operator.kernel.Transform$NoTransform">
                    <f idref="Tree" />
                </transformations>
            </operator>
            <operator id="StrictClockRateScalerX" spec="kernel.BactrianScaleOperator"
                parameter="@clockRate" upper="10.0" weight="3.0" />
        </operator>

        <operator id="strictClockUpDownOperator" spec="AdaptableOperatorSampler" weight="1.5">
            <parameter idref="clockRate" />
            <tree idref="Tree" />
            <operator idref="AVMNOperator.$(c)" />
            <operator id="strictClockUpDownOperatorX" spec="operator.kernel.BactrianUpDownOperator"
                scaleFactor="0.75" weight="3.0">
                <up idref="clockRate" />
                <down idref="Tree" />
            </operator>
        </operator> -->

        <operator id="gammaShapeScaler" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="gammaShape" />
            <!-- <operator idref="AVMNOperator.$(c)" /> -->
            <operator id="gammaShapeScalerX" spec="kernel.BactrianScaleOperator"
                parameter="@gammaShape" scaleFactor="0.5" upper="10.0" weight="0.1" />
        </operator>
        <operator id="KappaScaler" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="kappa" />
            <!-- <operator idref="AVMNOperator.$(c)" /> -->
            <operator id="KappaScalerX" spec="kernel.BactrianScaleOperator" parameter="@kappa"
                scaleFactor="0.1" upper="10.0" weight="0.1" />
        </operator>

        <operator id="ReEpiScaler" spec="ScaleOperator" parameter="@ReEpi" weight="3.0" />

        <operator id="dirichletOperator" spec="feast.modelselect.DirichletProcessOperator"
            parameter="@ReEpi" scaleParameter="@dirichletScale" baseDistr="@baseReDistr"
            weight="10">
        </operator>

        <!-- <operator id="smartReOperator" spec="feast.operators.SmartScaleOperator"
        parameter="@ReEpi"
              scaleFactor="0.75" weight="10"/> -->

        <operator id="dirichletScale_operator" spec="ScaleOperator" parameter="@dirichletScale"
            scaleFactor="0.8" weight="1.0" />


        <plate var="c" range="&clusters;">
            <operator id="BDMMPrimeLeafToSA$(c)"
                spec="sa.evolution.operators.LeafToSampledAncestorJump"
                tree="@Tree.$(c)" weight="10.0" />
            <operator id="BDMMPrimeSAWilsonBalding$(c)"
                spec="sa.evolution.operators.SAWilsonBalding"
                tree="@Tree.$(c)" weight="10.0" />
            <operator id="BDMMPrimeSAWide$(c)" spec="sa.evolution.operators.SAExchange"
                isNarrow="false"
                tree="@Tree.$(c)" weight="10.0" />
            <operator id="BDMMPrimeSANarrow$(c)" spec="sa.evolution.operators.SAExchange"
                tree="@Tree.$(c)"
                weight="10.0" />
            <operator id="BDMMPrimeSAUniformOperator$(c)" spec="sa.evolution.operators.SAUniform"
                tree="@Tree.$(c)" weight="20.0" />
            <operator id="BDMMPrimeSATreeRootScaler$(c)"
                spec="sa.evolution.operators.SAScaleOperator"
                rootOnly="true" scaleFactor="0.95" tree="@Tree.$(c)" weight="1.0" />
            <operator id="BDMMPrimeSATreeScaler$(c)" spec="sa.evolution.operators.SAScaleOperator"
                scaleFactor="0.95" tree="@Tree.$(c)" weight="3.0" />
            <operator id="samplingProportionEpi$(c)Scaler" spec="ScaleOperator"
                parameter="@samplingProportionEpi$(c)" weight="3.0" />
            <operator id="origin$(c)Scaler" spec="ScaleOperator" parameter="@origin$(c)"
                weight="3.0" />
        </plate>

        <!--  == Logging == -->

        <logger id="tracelog" spec="Logger" fileName="try_dpp.log" logEvery="10000"
            model="@posterior" sanitiseHeaders="true" sort="smart">
            <log idref="posterior" />
            <log idref="prior" />
            <log idref="clockRate" />
            <log idref="gammaShape" />
            <log idref="kappa" />
            <log idref="dirichletScale" />
            <log idref="dirichletScalePrior" />
            <!-- <log id="startTypePosteriorProbsLogger"
                spec="bdmmprime.util.StartTypePosteriorProbsLogger" bdmmTreePrior="@BDMMPrime" /> -->
            <!-- <log idref="ReSPEpi" /> -->
            <log id="uniqueReCount" spec="feast.function.UniqueElementCount" arg="@ReEpi" />
            <plate var="c" range="&clusters;">
                <!-- <log idref="ReChangeTimesEpi$(c)" /> -->
                <!-- <log idref="ReSPEpi$(c)" /> -->
                 <log idref="ReEpi$(c)" />
                <log idref="fso$(c)" />
                <log idref="samplingProportionSPEpi$(c)" />
                <log idref="origin$(c)" />
                <log idref="treeLikelihood$(c)" />
                <log idref="likelihood$(c)" />
                <log id="TreeHeight$(c)" spec="beast.base.evolution.tree.TreeStatLogger"
                    tree="@Tree.$(c)" />
            </plate>
        </logger>


        <logger id="screenlog" spec="Logger" logEvery="100000">
            <log spec="feast.function.UniqueElementCount" arg="@ReEpi" />
            <log idref="dirichletScale" />
            <log idref="dirichletScalePrior" />

            <log idref="posterior" />
            <!-- <log idref="likelihood" /> -->
            <log idref="prior" />
        </logger>

        <!-- <logger id="treelog" spec="Logger" fileName="$(filebase)-$(tree).trees"
        logEvery="10000"
            mode="tree">
            <log id="TreeWithMetaDataLogger" spec="beast.base.evolution.TreeWithMetaDataLogger"
                tree="@Tree.$(c)" />
        </logger> -->
        <!-- <logger id="typedTreeLogger" spec="bdmmprime.util.OptionalLogger"
            fileName="$(filebase).$(tree).typed.trees" logEvery="1000" mode="tree">
            <log id="typeMappedTree" spec="bdmmprime.mapping.TypeMappedTree"
                bdmmDistrib="@BDMMPrime" mapOnInit="false" remapOnLog="true"
                startTypePriorProbs="@startTypePriorProbs" typeLabel="type"
                typeTraitSet="@typeTraitSet" untypedTree="@Tree.$(c)" />
        </logger>
        <logger id="nodeTypedTreeLogger" spec="bdmmprime.util.OptionalLogger"
            fileName="$(filebase).$(tree).typed.node.trees" logEvery="1000" mode="tree">
            <log id="nodeTypedTree" spec="bdmmprime.mapping.TypedNodeTreeLogger"
                typedTree="@typeMappedTree" />
        </logger>
        <logger id="trajLogger" spec="bdmmprime.util.OptionalLogger"
            fileName="$(filebase).$(tree).traj" logEvery="1000">
            <log id="typedTraj" spec="bdmmprime.trajectories.SampledTrajectory"
                bdmmDistrib="@BDMMPrime" startTypePriorProbs="@startTypePriorProbs"
                typeMappedTree="@typeMappedTree" useTauLeaping="true" />
        </logger> -->
        <operatorschedule id="OperatorSchedule" spec="OperatorSchedule" />
    </run>

</beast>